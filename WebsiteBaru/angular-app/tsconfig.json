{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "node",
    "typeRoots": ["node_modules/@types"],
    "lib": ["es2020", "dom"],
    "forceConsistentCasingInFileNames": true,
    "strict": true
  }
}
