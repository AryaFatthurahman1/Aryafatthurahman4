# Configuration for Environment Variables
# Rename this file to .env and fill in your actual values

# ================================================
# Database Configuration
# ================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ml_api_db

# ================================================
# Flask Configuration
# ================================================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# ================================================
# Machine Learning Configuration
# ================================================
MODEL_PATH=./models/
DATA_PATH=./data/
UPLOAD_PATH=./uploads/

# ================================================
# API Configuration
# ================================================
API_HOST=localhost        # host or IP/domain where API will bind
API_PORT=5000             # port for Flask API
API_DEBUG=True
# Note: when running on server, point your clients to http://<API_HOST>:<API_PORT>
